    <dashboard name='Story 2' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text />
        </title>
      </layout-options>
      <style />
      <size maxheight='964' maxwidth='1216' minheight='964' minwidth='1216' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98340' id='1' param='vert' removable='false' type-v2='layout-flow' w='98684' x='658' y='830'>
            <zone h='1037' id='3' type-v2='title' w='98684' x='658' y='830' />
            <zone fixed-size='119' h='12344' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98684' x='658' y='1867' />
            <zone h='84959' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98684' x='658' y='14211'>
              <flipboard active-id='5' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Introduction' captured-sheet='' id='1' />
                  <story-point caption='USA Dominates Order Volume' captured-sheet='Orders by Country' id='2' />
                  <story-point caption='Revenue Concentrated Among Top Customers' captured-sheet='Top Customers' id='3' />
                  <story-point caption='Côte de Blaye Dominates Product Revenue' captured-sheet='Top Product' id='4' />
                  <story-point caption='Two Peak Periods Drive Annual Revenue' captured-sheet='Monthly Sales Trends' id='5' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' h='44191' hidden='true' id='6' story-point-id='1' type-v2='text' w='33268' x='33169' y='30083'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#4e79a7' fontsize='24'>Northwind Traders</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7' fontsize='24'>Business Performance Analysis</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7' fontsize='24'>An exploration of customer revenue, product performance,</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7' fontsize='24'>shipping efficiency and sales trends.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='63071' hidden='true' id='7' story-point-id='2' type-v2='text' w='13816' x='85609' y='23237'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#4e79a7' fontsize='12'>The USA leads all countries with 2,280 orders — nearly </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7' fontsize='12'>400 more than France in second place. European markets </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7' fontsize='12'>collectively represent a significant share of total orders.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='40249' hidden='true' id='8' story-point-id='3' type-v2='text' w='68750' x='3947' y='24689'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#4e79a7'>The top 3 customers — IT ($9.7M), B&apos;s Beverages ($6.2M), </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7'>and Hungry Coyote Import Store ($5.7M) — represent a </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7'>significant concentration of total revenue. Retaining </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7'>these key accounts should be a business priority.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='33195' hidden='true' id='9' story-point-id='4' type-v2='text' w='54852' x='22615' y='47925'>
          <formatted-text>
            <run fontcolor='#4e79a7'>Côte de Blaye generates $53.2M in revenue — more than </run>
            <run>Æ&#10;</run>
            <run fontcolor='#4e79a7'>double its nearest competitor Thüringer Rostbratwurst </run>
            <run>Æ&#10;</run>
            <run fontcolor='#4e79a7'>at $24.6M. Critically, Thüringer Rostbratwurst currently </run>
            <run>Æ&#10;</run>
            <run fontcolor='#4e79a7'>has zero stock and zero reorders placed, representing </run>
            <run>Æ&#10;</run>
            <run fontcolor='#4e79a7'>significant lost revenue risk for the business.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='29876' id='10' story-point-id='5' type-v2='text' w='44490' x='18092' y='59232'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#4e79a7'>2013 revenue shows two distinct peak periods — a mid year </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7'>surge in July and an early fall spike in September — followed </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7'>by a building trend toward December. The business should align </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7'>inventory and staffing around these three peak windows to </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#4e79a7'>maximize revenue potential.</run>
          </formatted-text>
